crypto_market_project:
  target: dev
  outputs:
    dev:
      type: bigquery
      # Use a file path — not inline JSON — so the private key PEM newlines stay valid.
      method: service-account
      project: "{{ env_var('GCP_PROJECT_ID') }}"
      dataset: "{{ env_var('BQ_DATASET_ANALYTICS', 'crypto_analytics') }}"
      location: "{{ env_var('GCP_REGION', 'us-central1') }}"
      keyfile: "{{ env_var('GOOGLE_APPLICATION_CREDENTIALS') }}"
      threads: 4
      timeout_seconds: 300
      priority: interactive
