# Copy to ".env" in the repo root (same folder as docker-compose.yml).
#   PowerShell:  Copy-Item .env.example .env
#   CMD:         copy .env.example .env
# Docker Compose loads .env automatically; missing file is OK for `ci` profile only.
# For batch/stream/dbt in Docker, fill GCP_* and mount your SA key (see docker-compose.yml header).

# GCP configuration (non-secret)
GCP_PROJECT_ID=your-project-id
GCP_REGION=us-central1
GCS_BUCKET=your-unique-bucket-name

# BigQuery datasets
BQ_DATASET_RAW=crypto_raw
BQ_DATASET_ANALYTICS=crypto_analytics
# Must use the same project id as GCP_PROJECT_ID (not the literal your-project-id).
BQ_RAW_STREAM_TABLE=your-project-id.crypto_raw.raw_stream_trades

# Optional: override raw table id for batch (else built from project + BQ_DATASET_RAW)
# BQ_RAW_TABLE=your-project-id.crypto_raw.raw_batch_ohlc

# Pub/Sub names
PUBSUB_TOPIC=crypto-trades-topic
PUBSUB_SUBSCRIPTION=crypto-trades-sub

# Binance settings
BINANCE_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT
# Must match the kline interval loaded into raw_batch_ohlc (batch script defaults to 1m if unset).
BATCH_INTERVAL=1m

# Batch: set to 1 to write to GCS/BigQuery (requires bucket, table, credentials)
RUN_BATCH_PIPELINE=0

# Auth — local Python + dbt: path to service account JSON (dbt profiles use this file path; do not paste JSON into env)
# GOOGLE_APPLICATION_CREDENTIALS=C:/path/to/your-service-account.json
#
# Docker Compose (batch / stream / dbt): folder docker/ is mounted at /run/gcp in the container.
# Default key path: docker/service-account.json  ->  /run/gcp/service-account.json
# If your JSON is nested (e.g. docker/sa.json is a folder and the file is inside it), set:
# GCP_CREDENTIALS_CONTAINER_PATH=/run/gcp/sa.json/your-key-filename.json

